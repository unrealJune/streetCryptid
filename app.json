{
  "expo": {
    "name": "streetCryptid",
    "slug": "streetCryptid",
    "owner": "streetcryptid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "streetcryptid",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.unrealjune.streetcryptid",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "streetCryptid uses Bluetooth while you arm Bump to find the phone you tap and start an encrypted pairing.",
        "NSLocalNetworkUsageDescription": "streetCryptid finds friends' phones on the same Wi-Fi so it can share your location directly, without routing through a relay.",
        "NSBonjourServices": ["_irohv1._udp"],
        "UIBackgroundModes": ["location", "remote-notification", "processing"]
      }
    },
    "android": {
      "package": "com.unrealjune.streetcryptid",
      "adaptiveIcon": {
        "backgroundColor": "#EEF2F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "streetcryptid",
              "host": "social"
            },
            {
              "scheme": "streetcryptid",
              "host": "pair"
            }
          ]
        }
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "ACCESS_LOCAL_NETWORK",
        "ACCESS_NETWORK_STATE",
        "NEARBY_WIFI_DEVICES",
        "CHANGE_WIFI_MULTICAST_STATE"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EEF2F5",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "streetCryptid shares your location only with friends you choose.",
          "locationAlwaysAndWhenInUsePermission": "streetCryptid keeps sharing your location with chosen friends while the app is in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "androidForegroundServiceIcon": "./assets/images/android-icon-monochrome.png"
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "fbcfc544-2532-4cb2-b69b-9403470d12e8"
      }
    }
  }
}
