# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
target/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Signing credentials — NEVER commit (keystore + passwords)
/credentials/
credentials.json

# Internal-only Play Store runbooks (not for the public repo)
docs/play-store/

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# EAS store metadata — contains the App Store review contact (phone/email); keep local
store.config.json

# self-hosted infra (private tile server, baked tilesets, etc.) — not part of the public app.
# infra/* (not infra/) so the negation below can re-include the shareable otel dev stack.
infra/*
!infra/otel/

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

# local Expo module build outputs
modules/iroh-location/web/
modules/iroh-location/android/.gradle/
modules/iroh-location/android/build/
modules/iroh-location/android/src/main/jniLibs/
modules/iroh-location/ios/headers/
modules/iroh-location/ios/IrohLocationFFI.xcframework/
