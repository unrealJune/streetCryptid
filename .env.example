# Public runtime endpoints. Copy to .env.local and replace with reachable deployments.
EXPO_PUBLIC_TILE_URL=https://tiles.example.com/washington
EXPO_PUBLIC_IROH_RELAY_URLS=https://relay.example.com
EXPO_PUBLIC_IROH_RELAY_TOKEN=replace-with-limited-scope-client-token
EXPO_PUBLIC_PAIR_MAILBOX_URL=https://mailbox.example.com

# Optional offline-delivery trail stash (https://github.com/unrealJune/trail-stash). Leave unset to
# disable the feature (peer-only reconciliation). Both URL and ticket are required to enable it; PSK
# is the anti-abuse
# pre-shared key (mirrors the relay token) and must match the server's TRAIL_STASH_PSK.
EXPO_PUBLIC_TRAIL_STASH_URL=https://stash.example.com
EXPO_PUBLIC_TRAIL_STASH_TICKET=replace-with-stash-node-endpoint-ticket
EXPO_PUBLIC_TRAIL_STASH_PSK=replace-with-limited-scope-client-token

# DEVELOPER-ONLY telemetry (traces + logs → the infra/otel collector; see infra/otel/README.md).
# Set to the OTLP/HTTP endpoint the PHONE can reach (LAN IP, not localhost). Unset ⇒ telemetry is
# completely inert. Never set this in the production build profile.
EXPO_PUBLIC_OTEL_ENDPOINT=http://192.168.1.10:4318
